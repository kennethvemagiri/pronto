# ============================================
# CLOUD AI - OpenAI (recommended for hosted)
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
PRONTO_OPENAI_MODEL=gpt-4o-mini
# Set provider to "openai" to use OpenAI instead of Ollama:
# PRONTO_LLM_PROVIDER=openai

# ============================================
# LOCAL AI (recommended) — Ollama
# ============================================
# Install Ollama and run a model locally, e.g.:
#   ollama pull llama3
#   ollama serve
#
# Then pronto will call Ollama at this base URL:
PRONTO_OLLAMA_BASE_URL=http://127.0.0.1:11434
#
# Choose the model name you pulled:
PRONTO_OLLAMA_MODEL=llama3
#
# LLM backend: use "ollama" (local) or "openai" (requires OPENAI_API_KEY above).
# PRONTO_LLM_PROVIDER=ollama

# ============================================
# OPTIONAL - Supabase (for authentication & history)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
# Get these from: https://supabase.com/dashboard

# ============================================
# OPTIONAL - Server Configuration
# ============================================
PORT=3000
NODE_ENV=development
# Use NODE_ENV=production in production
